# Copy to backend/.env.local and fill in real values. .env.local is gitignored.

# ---------- Database ----------
# Container-to-container resolution uses `db` (the docker-compose service name).
# Override for local-only runs without docker compose: postgresql://...@localhost:5432/mydb
DATABASE_URL=postgresql://myuser:mypassword@db:5432/mydb

# ---------- App basics ----------
ENV=LOCAL
HOST=0.0.0.0
PORT=8000

# ---------- Firebase Admin SDK (one of three configurations) ----------
# Pick one of (A), (B), or (C) — the SDK init in backend/config/firebase.py
# raises on startup if none is set.

# (A) Real Firebase project — service-account JSON, two flavors:
#
#   (A.1) Mounted file (recommended for local dev):
#         Drop the JSON at backend/firebase-service-account.json (gitignored)
#         and set the in-container path here. `backend/` is bind-mounted to
#         /backend per docker-compose.yml, so the path inside the container is:
#GOOGLE_APPLICATION_CREDENTIALS=/backend/firebase-service-account.json
#FIREBASE_PROJECT_ID=traders-edge-ddea1
#
#   (A.2) Inline JSON (works when you can't easily mount a file, e.g. some
#         hosted runners). The whole service-account JSON on one line —
#         `jq -c . path/to/key.json` compacts it for you:
#FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"traders-edge-ddea1","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxx@traders-edge-ddea1.iam.gserviceaccount.com",...}
#FIREBASE_PROJECT_ID=traders-edge-ddea1

# (B) Local Auth emulator (matches the CI workflow). Two gotchas vs. running
#     outside Docker:
#       1. `host.docker.internal` instead of 127.0.0.1 — the container can't
#          reach the host loopback. Works on macOS/Windows out of the box;
#          on Linux add `extra_hosts: ["host.docker.internal:host-gateway"]`
#          to the backend service in docker-compose.yml.
#       2. No scheme — firebase-admin (Python) wants `host:port`, NOT
#          `http://host:port`. The frontend SDK is the opposite.
#FIREBASE_AUTH_EMULATOR_HOST=host.docker.internal:9099
#FIREBASE_PROJECT_ID=demo-traders-edge
