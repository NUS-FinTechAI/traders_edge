# Copy to .env.local and fill in real values. Vite exposes only VITE_*-prefixed
# variables to the bundle. These end up in the shipped JS; that's expected for
# Firebase Web SDK — the API key is a project identifier, not a secret.

VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# Firebase Web app config (Project settings → Your apps → Web app):
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Optional. Set to point the Web SDK at a local Auth emulator instead of Google:
#   VITE_FIREBASE_AUTH_EMULATOR_HOST=http://localhost:9099
